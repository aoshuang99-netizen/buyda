{
  "manifest_version": 3,
  "name": "Buyda个性化选品智能体",
  "version": "2.3.0",
  "description": "Buyda v2.3 - 决策指挥中心+双层分组导航+Sophos企业级UI：AI选品总结、风险拦截雷达、行动剧本",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.cn/*",
    "*://*.1688.com/*",
    "*://api.keepa.com/*",
    "*://api.openai.com/*",
    "*://api.anthropic.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.amazon.com/*", "*://*.amazon.cn/*"],
      "js": ["amazon-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.1688.com/*"],
      "js": ["1688-content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

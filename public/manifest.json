{
  "manifest_version": 3,
  "name": "AI选品助手",
  "version": "1.0.0",
  "description": "AI驱动的跨境电商选品工具，帮助卖家快速发现高利润产品，智能匹配优质货源",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.cn/*",
    "*://*.keepa.com/*",
    "*://*.1688.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.amazon.com/*", "*://*.amazon.cn/*"],
      "js": ["amazon-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.1688.com/*"],
      "js": ["1688-content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
